/** 全局样式与主题变量 - 统一风格（明亮柔和玻璃） **/
page {
  /* 主题配色：电动车租赁 · 明亮柔和玻璃风 */
  --primary: #22c55e;
  --primary-soft: rgba(34, 197, 94, 0.16);
  --primary-strong: #15803d;
  --accent: #0ea5e9;
  --accent-soft: rgba(14, 165, 233, 0.16);

  --bg-page: radial-gradient(circle at 0% 0%, #e0f2fe 0%, #f9fafb 40%, #f1f5f9 100%);
  --bg-page-solid: #f1f5f9;
  --bg-glass: rgba(255, 255, 255, 0.86);
  --bg-glass-soft: rgba(255, 255, 255, 0.92);

  --text-title: #0f172a;
  --text-body: #475569;
  --text-muted: #94a3b8;
  --text-weak: #9ca3af;

  --border-glass: rgba(148, 163, 184, 0.35);
  --border-strong: rgba(148, 163, 184, 0.65);

  --radius: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 40rpx;
  --radius-pill: 999rpx;

  --shadow-strong: 0 18rpx 60rpx rgba(15, 23, 42, 0.16);
  --shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.12);
  --shadow-soft: 0 8rpx 28rpx rgba(15, 23, 42, 0.08);

  --transition: 0.22s ease-out;

  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  background: var(--bg-page);
  box-sizing: border-box;
  font-size: 28rpx;
  color: var(--text-body);
}

/* 通用布局容器 */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: transparent;
  background-image:
    radial-gradient(circle at 0% 0%, rgba(56, 189, 248, 0.18), transparent 55%),
    radial-gradient(circle at 100% 20%, rgba(74, 222, 128, 0.18), transparent 55%);
}
.page .scroll-body {
  flex: 1;
  height: 0;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

/* 顶部搜索栏 · 玻璃胶囊 */
.search-bar-wrap {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.98), rgba(241, 245, 249, 0.96));
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.9);
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(148, 163, 184, 0.28);
}
.search-bar-wrap .search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 30rpx;
  font-size: 26rpx;
  color: var(--text-title);
  background: #f8fafc;
  border-radius: var(--radius-pill);
  border: 1rpx solid rgba(148, 163, 184, 0.55);
  box-shadow:
    0 10rpx 22rpx rgba(148, 163, 184, 0.25),
    0 0 0 1rpx rgba(241, 245, 249, 0.9);
}
.search-bar-wrap .search-input::placeholder {
  color: var(--text-weak);
}

/* 通用玻璃卡片 */
.glass-card {
  position: relative;
  margin: 0 28rpx 28rpx;
  padding: 34rpx 32rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-glass);
  border: 1rpx solid var(--border-glass);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.glass-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 0% 0%, rgba(56, 189, 248, 0.14), transparent 60%),
    radial-gradient(circle at 100% 100%, rgba(74, 222, 128, 0.14), transparent 60%);
  opacity: 0.7;
  pointer-events: none;
}
.glass-card-inner {
  position: relative;
  z-index: 1;
}

/* 通用区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-title);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.section-title-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 30%, #bbf7d0, var(--primary));
  box-shadow: 0 0 22rpx rgba(74, 222, 128, 0.9);
}
.section-title-sub {
  font-size: 22rpx;
  color: var(--text-weak);
}

/* 标签与状态 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--primary-strong);
  background: rgba(240, 253, 250, 0.95);
  border: 1rpx solid rgba(187, 247, 208, 0.9);
}
.tag-primary {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.12), rgba(240, 253, 250, 0.9));
  border-color: rgba(34, 197, 94, 0.5);
  color: #166534;
}
.tag-accent {
  background: linear-gradient(135deg, rgba(14, 165, 233, 0.12), rgba(239, 246, 255, 0.96));
  border-color: rgba(14, 165, 233, 0.5);
  color: #075985;
}

/* 主按钮 */
.btn-primary {
  height: 88rpx;
  padding: 0 44rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, #22c55e, #0ea5e9);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow:
    0 16rpx 32rpx rgba(34, 197, 94, 0.35),
    0 0 30rpx rgba(56, 189, 248, 0.45);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.96;
}

/* 次按钮 */
.btn-ghost {
  height: 88rpx;
  padding: 0 44rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.9);
  color: var(--text-body);
  font-size: 28rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.6);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}
.btn-ghost:active {
  opacity: 0.9;
}
