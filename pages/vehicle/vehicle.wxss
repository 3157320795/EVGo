/* 车辆页 - 玻璃拟态风格 */
page {
  height: 100%;
  background: var(--bg-page-solid);
}
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.main {
  flex: 1;
  display: flex;
  min-height: 0;
  height: 0;
}

/* 左侧分类 tab：玻璃侧栏 */
.tabs {
  width: 180rpx;
  height: 100%;
  flex-shrink: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(241, 245, 249, 0.96));
  border-right: 1rpx solid rgba(226, 232, 240, 0.9);
  box-shadow: 12rpx 0 32rpx rgba(148, 163, 184, 0.24);
}
.tab-item {
  padding: 32rpx 24rpx;
  font-size: 24rpx;
  color: var(--text-weak);
  text-align: center;
  position: relative;
}
.tab-item.active {
  color: var(--primary-strong);
  font-weight: 600;
}
.tab-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: linear-gradient(180deg, #22c55e, #0ea5e9);
  border-radius: 0 999rpx 999rpx 0;
}

/* 车辆列表 */
.list {
  flex: 1;
  height: 100%;
  min-width: 0;
  padding: 24rpx 24rpx 24rpx 20rpx;
  box-sizing: border-box;
}
.vehicle-card {
  margin: 0 0 24rpx;
}
.card {
  display: flex;
  align-items: stretch;
}
.card-img {
  width: 260rpx;
  height: 208rpx;
  flex-shrink: 0;
  border-radius: calc(var(--radius-lg) - 8rpx);
  background: radial-gradient(circle at 0% 0%, rgba(56, 189, 248, 0.32), rgba(15, 23, 42, 0.96));
}
.card-info {
  flex: 1;
  padding-left: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
  gap: 18rpx;
}
.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-title);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-meta {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 12rpx;
}
.meta-item {
  font-size: 22rpx;
  color: var(--text-weak);
}
.dot {
  color: var(--text-weak);
  font-size: 24rpx;
}
.card-bottom {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 12rpx;
}
.price-wrap {
  display: flex;
  flex-direction: column;
}
.card-price {
  font-size: 30rpx;
  color: #26e669;
  font-weight: 700;
}
.price-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-weak);
}
.status-tags {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.empty {
  text-align: center;
  padding: 140rpx 40rpx;
  font-size: 26rpx;
  color: var(--text-weak);
}
