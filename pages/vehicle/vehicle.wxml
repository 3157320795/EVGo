<!--车辆列表页 · 电动车租赁 · 玻璃拟态风格-->
<view class="page">
  <view class="search-bar-wrap">
    <input
      class="search-input"
      placeholder="搜索可租车辆 / 续航 / 价格"
      value="{{keyword}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <view class="main">
    <!-- 左侧分类 tab：全部、外卖车、代步车 -->
    <scroll-view class="tabs" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        class="tab-item {{activeCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCategoryTap"
      >
        {{item.name}}
      </view>
    </scroll-view>

    <!-- 右侧车辆列表 -->
    <scroll-view class="list" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        class="vehicle-card glass-card"
        wx:for="{{filteredList}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="toDetail"
      >
        <view class="glass-card-inner">
          <view class="card">
            <image class="card-img" src="{{item.image}}" mode="aspectFill" />
            <view class="card-info">
              <view class="card-header">
                <text class="card-name">{{item.name}}</text>
                <text class="tag tag-primary" wx:if="{{item.isHot}}">热租</text>
              </view>
              <view class="card-meta">
                <text class="meta-item">{{item.voltage}}</text>
                <text class="dot">·</text>
                <text class="meta-item">{{item.range}}</text>
              </view>
              <view class="card-bottom">
                <view class="price-wrap">
                  <text class="card-price">
                    {{item.priceUnit === '月' ? item.price + ' 元/月' : '¥ ' + item.price + '/天'}}
                  </text>
                  <text class="price-sub" wx:if="{{item.deposit}}">押金 {{item.deposit}} 元</text>
                </view>
                <view class="status-tags">
                  <text class="tag-accent tag" wx:if="{{item.availableCount > 0}}">
                    可租 {{item.availableCount}} 台
                  </text>
                  <text class="tag" wx:else>可预约</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="empty" wx:if="{{filteredList.length === 0}}">暂无可租车辆</view>
    </scroll-view>
  </view>
</view>
