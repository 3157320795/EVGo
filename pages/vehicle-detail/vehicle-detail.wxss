/* 车辆详情 - 玻璃拟态风格（明亮） */
page {
  height: 100%;
  background: var(--bg-page-solid);
}
.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}
.content {
  flex: 1;
  height: 0;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}
.page .empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-weak);
}

.detail-hero {
  padding-bottom: 20rpx;
}
.detail-swiper {
  width: 100%;
  height: 440rpx;
}
.detail-banner {
  height: 100%;
}
.detail-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
}

/* 信息卡片 */
.info {
  padding-top: 26rpx;
  padding-bottom: 30rpx;
}
.name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}
.name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-title);
  line-height: 1.4;
}
.tag-row {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 26rpx;
}
.price {
  font-size: 40rpx;
  color: #82bb96;
  font-weight: 700;
}
.price-unit {
  font-size: 24rpx;
  color: var(--text-weak);
}
.specs {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}
.spec-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: var(--radius-pill);
  background: rgba(240, 249, 255, 0.95);
  border: 1rpx solid rgba(191, 219, 254, 0.9);
  font-size: 24rpx;
}
.spec-item .k {
  color: var(--text-weak);
  margin-right: 10rpx;
}
.spec-item .v {
  color: var(--text-title);
  font-weight: 500;
}
.note-card {
  margin-top: 22rpx;
  padding: 20rpx 22rpx;
  border-radius: var(--radius);
  background: rgba(248, 250, 252, 0.95);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}
.note-title {
  font-size: 24rpx;
  color: var(--text-title);
  font-weight: 600;
  margin-bottom: 12rpx;
}
.note-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}
.note-item + .note-item {
  margin-top: 8rpx;
}
.note-dot {
  color: #82bb96;
  line-height: 1.6;
}
.note-text {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-body);
  line-height: 1.6;
}

/* 联系店铺卡片 */
.contact-card {
  margin-top: 16rpx;
  margin-bottom: 28rpx;
}
.contact-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
}
.contact-text {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.contact-title {
  font-size: 30rpx;
  color: var(--text-title);
  font-weight: 600;
}
.contact-sub {
  font-size: 22rpx;
  color: var(--text-weak);
}
.phone {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary-strong);
}

.empty {
  padding: 140rpx 40rpx;
  text-align: center;
  color: var(--text-weak);
  font-size: 28rpx;
}
